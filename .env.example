# Database (host-side port — Docker maps host:5435 → container:5432)
DATABASE_URL="postgresql://learnstack:learnstack@localhost:5435/learnstack"

# JWT secrets — generate with: openssl rand -hex 32
JWT_SECRET="change-me-32-chars-minimum-secret"
JWT_REFRESH_SECRET="change-me-32-chars-minimum-refresh-secret"

# Allow local filesystem paths in forkUrl (for dev/testing only — set false in production)
ALLOW_LOCAL_FORK_PATHS=true

# Path to the learnstack-qa-track repo (content source)
# Docker mounts this at /content; set to local path for non-Docker dev
CONTENT_REPO_PATH="../learnstack-qa-track"

# API port
PORT=3001

# Vite dev server proxies /api to this URL
VITE_API_URL="http://localhost:3001"
